# Copy to `.env` (gitignored) and fill in. Loaded into the shell before
# running a `*-live` build — the binaries read plain env vars, never files.
# PowerShell:  Get-Content .env | ForEach-Object { $k,$v = $_ -split '=',2; if ($k -and -not $k.StartsWith('#')) { Set-Item "env:$k" $v } }
# POSIX:       set -a; . ./.env; set +a

# ACLED (M5, feature `acled-live`): free myACLED account, https://acleddata.com
# OAuth password grant — ACLED retired API keys; there is no ACLED_API_KEY.
ACLED_EMAIL=
ACLED_PASSWORD=
